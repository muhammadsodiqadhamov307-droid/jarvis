# Backend
PORT=3001
FRONTEND_ORIGIN=http://localhost:5174
DEFAULT_ADDRESS=Sir
USER_TIMEZONE=Asia/Tashkent
DATABASE_PROVIDER=sqlite
DATABASE_URL=
DATABASE_SSL=false
SQLITE_PATH=./backend/database.sqlite
JARVIS_SERVE_FRONTEND=false
JARVIS_STARTUP_COMMAND=

# Gemini
# Required for Gemini text and Live voice proxy.
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_TEXT_MODEL=gemini-2.5-flash
GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts

# Live API model names vary by Gemini Developer API / Vertex AI availability.
# Vertex examples include gemini-live-2.5-flash-native-audio.
# Developer API preview deployments may use a different live-capable model.
GEMINI_LIVE_MODEL=gemini-2.5-flash-native-audio-preview-12-2025
GEMINI_VOICE=Charon
GEMINI_LIVE_SILENCE_MS=1200

# Optional override if Google changes the websocket endpoint or you are proxying Vertex AI.
GEMINI_LIVE_WS_URL=wss://generativelanguage.googleapis.com/ws/google.ai.generativelanguage.v1beta.GenerativeService.BidiGenerateContent

# Voice provider. ElevenLabs is primary for natural British/JARVIS-style speech;
# Gemini TTS remains available as fallback when configured.
TTS_PROVIDER=live
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb
ELEVENLABS_MODEL=eleven_flash_v2_5

# Search: configure one provider.
TAVILY_API_KEY=
SERPAPI_KEY=

# Frontend
VITE_API_URL=http://localhost:3001
VITE_API_WS=ws://localhost:3001/ws/gemini-live
VITE_TTS_PROVIDER=live
VITE_ENABLE_LIVE_AUDIO=true
VITE_SPEECH_RECOGNITION_LANG=en-US
